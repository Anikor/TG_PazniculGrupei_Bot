# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor / IDE cruft
.vs/
.idea/
*.suo
*.user
*.swp
*~

# Logs — also catches Testing/GroupJournalBot/user_ids.log if it's ever
# regenerated; the copy already in git history needs a separate history
# rewrite (see CHANGES.md §5), this just stops it from coming back.
*.log

# Local environment / secrets — dev.sh's BOT_TOKEN default is a throwaway
# dummy and safe to commit; a real .env would not be.
.env
.env.local
.env.*.local

# PHP built-in server session files, if ever written inside the repo dir
# instead of the system tmp dir.
sess_*

# Local-only: dev/test tooling and internal writeups, kept off GitHub by
# choice. tg_auth.php is NOT here — it's the actual fix, required at
# runtime by export.php/greeting.php/index.php/etc., and must be committed.
dev.sh
/tools/
/tests/
RUNBOOK.md
TESTING.md
OPTIMIZATION.md
INTEGRATION.md
CHANGES.md
